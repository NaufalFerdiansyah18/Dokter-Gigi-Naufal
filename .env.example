# ================================
# SERVICE AUTOMATION CONFIGURATION
# ================================

# WhatsApp Notification (Fonnte / Wablas)
# Dapatkan dari: https://fonnte.com/ atau https://wablas.com/
VITE_WHATSAPP_API_URL=https://api.fonnte.com/send
VITE_WHATSAPP_API_KEY=your_whatsapp_api_key_here
VITE_WHATSAPP_ENABLED=true

# Email Notification (EmailJS / SendGrid)
# Dapatkan dari: https://www.emailjs.com/
VITE_EMAIL_SERVICE_ID=service_xxxxxxx
VITE_EMAIL_TEMPLATE_ID=template_xxxxxxx
VITE_EMAIL_PUBLIC_KEY=your_public_key_here
VITE_EMAIL_ENABLED=true

# ================================
# SUPABASE CONFIGURATION
# ================================
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ================================
# APP CONFIGURATION
# ================================
VITE_APP_NAME="Dentiva Clinic"
VITE_APP_URL=http://localhost:5173

# ================================
# NOTES
# ================================
# 1. Copy file ini menjadi .env untuk development
# 2. Jangan commit file .env ke git (sudah di .gitignore)
# 3. Untuk production, set environment variables di hosting platform
# 4. Ganti semua nilai 'your_xxx_here' dengan credentials yang sebenarnya
